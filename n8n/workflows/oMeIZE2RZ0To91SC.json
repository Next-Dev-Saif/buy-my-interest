      "id": "fetch-prem-buyers-id",
      "name": "Fetch-Premium-Buyers"
    },
    {
      "parameters": {
        "jsCode": "const seller = $(\"Buyer-Or-Seller1\").first().json;\nconst sellerInterests = (seller.interestedItems || []).map(i => i.toLowerCase().trim());\nconst sellerLocations = (seller.interestedLocations || []).map(l => l.toLowerCase().trim());\n\n// Correctly extract the 'data' array from the HTTP response objects\nconst extractData = (nodeName) => {\n  try {\n    const response = $(nodeName).first().json;\n    return response.data || [];\n  } catch (e) {\n    return [];\n  }\n};\n\nconst allBuyers = [\n  ...extractData(\"Fetch-Free-Buyers\"),\n  ...extractData(\"Fetch-Priority-Buyers\"),\n  ...extractData(\"Fetch-Premium-Buyers\")\n];\n\nconst matches = [];\nfor (const buyer of allBuyers) {\n  if (buyer.userType !== 'buyer' || buyer.email === seller.email) continue;\n\n  // Handle both array and string interests (robustness)\n  const bInterests = Array.isArray(buyer.interestedItems) ? buyer.interestedItems : [buyer.interestedItems || \"\"];\n  const bLocations = Array.isArray(buyer.interestedLocations) ? buyer.interestedLocations : [buyer.interestedLocations || \"\"];\n\n  const buyerInterests = bInterests.map(i => i.toLowerCase().trim());\n  const buyerLocations = bLocations.map(l => l.toLowerCase().trim());\n\n  const sharedInterests = sellerInterests.filter(si => \n    buyerInterests.some(bi => bi.includes(si) || si.includes(bi))\n  );\n  \n  const sharedLocations = sellerLocations.filter(sl => \n    buyerLocations.some(bl => bl.includes(sl) || sl.includes(bl))\n  );\n\n  if (sharedInterests.length > 0 && sharedLocations.length > 0) {\n    matches.push({\n      title: `Interested Buyer: ${buyer.fullName}`,\n      price: 'Prospect Found',\n      category: sharedInterests[0],\n      location: sharedLocations[0],\n      description: `${buyer.fullName} is interested in ${bInterests.join(', ')} in ${bLocations.join(', ')}.`,\n      imageUrl: '',\n      sourceUrl: `mailto:${buyer.email}`,\n      dateScraped: new Date().toISOString(),\n      metadata: {\n        buyerEmail: buyer.email,\n        sharedInterests,\n        sharedLocations\n      }\n    });\n  }\n}\n\nreturn { userEmail: seller.email, matches };\n"
      },
