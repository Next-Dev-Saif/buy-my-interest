    {
      "parameters": {
        "jsCode": "let allPassed = true;\nconst results = [];\n\n// Helper function to clean common AI-generated JSON wrappers/issues\nfunction cleanJsonString(str) {\n  if (typeof str !== \"string\") return str;\n\n  let cleaned = str.trim();\n\n  // Remove markdown code fences\n  cleaned = cleaned.replace(/^```(?:json)?\\s*/i, \"\");\n  cleaned = cleaned.replace(/\\s*```$/i, \"\");\n\n  // Remove surrounding backticks\n  cleaned = cleaned.replace(/^`+|`+$/g, \"\");\n\n  // Remove leading/trailing unwanted text before/after JSON\n  const firstBrace = cleaned.search(/[\\[{]/);\n  const lastBrace = Math.max(\n    cleaned.lastIndexOf(\"}\"),\n    cleaned.lastIndexOf(\"]\")\n  );\n\n  if (firstBrace !== -1 && lastBrace !== -1) {\n    cleaned = cleaned.slice(firstBrace, lastBrace + 1);\n  }\n\n  // Remove BOM and invisible characters\n  cleaned = cleaned.replace(/^\\uFEFF/, \"\");\n\n  return cleaned.trim();\n}\n\nfor (const item of $input.all()) {\n  try {\n    let rawOutput = item.json.output;\n\n    // First attempt: direct parse\n    try {\n      results.push({\n        isPassed: true,\n        output: JSON.parse(rawOutput),\n      });\n      continue;\n    } catch (_) {}\n\n    // Second attempt: cleaned parse\n    const cleanedOutput = cleanJsonString(rawOutput);\n\n    try {\n      results.push({\n        isPassed: true,\n        output: JSON.parse(cleanedOutput),\n      });\n    } catch (e) {\n      results.push({\n        isPassed: false,\n        output: item.json.output,\n        error: e.message,\n      });\n\n      allPassed = false;\n    }\n  } catch (e) {\n    results.push({\n      isPassed: false,\n      output: item.json.output,\n      error: e.message,\n    });\n\n    allPassed = false;\n  }\n}\n\nreturn [\n  {\n    json: {\n      isPassed: allPassed,\n      details: results,\n    },\n  },\n];"
      },
