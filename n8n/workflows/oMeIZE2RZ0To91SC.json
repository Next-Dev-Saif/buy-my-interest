        "jsCode": "const seen = new Set(); const merged = []; for (const item of $input.all()) { const details = item.json?.details || []; for (const detail of details) { if (!detail.isPassed) continue; const items = detail.output?.items || []; for (const entry of items) { const key = `${(entry.title || '').toLowerCase().trim()}|${entry.price}`; if (!seen.has(key)) { seen.add(key); merged.push(entry); } } } } return [{ json: { mergedItems: merged } }];"
      },
