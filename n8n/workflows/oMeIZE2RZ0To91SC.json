    {
      "parameters": {
        "jsCode": "function extractCleanBody(html) { if (!html) return ''; const bodyMatch = html.match(/<body[^>]*>([\\s\\S]*?)<\\/body>/i); let body = bodyMatch ? bodyMatch[1] : html; body = body.replace(/<script[\\s\\S]*?<\\/script>/gi, ''); body = body.replace(/<style[\\s\\S]*?<\\/style>/gi, ''); body = body.replace(/<noscript[\\s\\S]*?<\\/noscript>/gi, ''); body = body.replace(/<svg[\\s\\S]*?<\\/svg>/gi, ''); body = body.replace(/<iframe[\\s\\S]*?<\\/iframe>/gi, ''); body = body.replace(/<!--[\\s\\S]*?-->/g, ''); body = body.replace(/\\s+/g, ' ').trim(); return body; } const CHUNK_SIZE = 12000; const html = $json.content || ''; const body = extractCleanBody(html); const blockSplitRegex = /(?=<(?:div|section|article|li|tr|ul|ol|table|main|aside|header|footer|p)[^>]*>)/gi; const parts = body.split(blockSplitRegex).filter(p => p.trim().length > 50); const chunks = []; let current = ''; for (const part of parts) { if ((current + part).length > CHUNK_SIZE) { if (current.trim()) chunks.push(current.trim()); current = part; } else { current += part; } } if (current.trim()) chunks.push(current.trim()); const cappedChunks = chunks.slice(0, 10); if (cappedChunks.length === 0) { return [{ json: { chunkIndex: 0, totalChunks: 1, bodyContent: body.slice(0, CHUNK_SIZE) } }]; } return cappedChunks.map((chunk, index) => ({ json: { chunkIndex: index, totalChunks: cappedChunks.length, bodyContent: chunk } }));"
      },
