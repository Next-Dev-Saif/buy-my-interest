    {
      "parameters": {
        "jsCode": "const userContext = $(\"Extract-Interested-Items1\").first().json.user; const currentEmail = userContext.email; const groups = {}; const allQueries = $(\"Extract-Interested-Items1\").all(); for (const item of $(\"Search-Google1\").all()) { const inputIndex = item.pairedItem?.item; if (inputIndex !== undefined && allQueries[inputIndex]) { const inputData = allQueries[inputIndex].json; const itemUserEmail = inputData.user?.email; if (itemUserEmail === currentEmail) { if (!groups[currentEmail]) { groups[currentEmail] = { userEmail: currentEmail, results: [] }; } const organic = item.json.organic_results || []; groups[currentEmail].results.push(...organic.map(r => ({ ...r, category: inputData.product }))); } } } return Object.values(groups).map(g => ({ json: g }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4464, 352],
      "id": "2a3a54ca-8a78-43eb-b55f-1a48af58075f",
      "name": "Aggregate-Search-Results1"
    },
    {
      "parameters": {
        "jsCode": "let items = []; for (const item of $input.all()) { const { results, userEmail } = item.json; results.slice(0, 5).forEach((result) => { items.push({ json: { userEmail, link: result.link, category: result.category } }); }); } return items;"
