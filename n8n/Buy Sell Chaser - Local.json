    {
      "parameters": {
        "jsCode": "function extractCleanBody(html) { if (!html) return ''; const bodyMatch = html.match(/<body[^>]*>([\\s\\S]*?)<\\/body>/i); let body = bodyMatch ? bodyMatch[1] : html; body = body.replace(/<script[\\s\\S]*?<\\/script>/gi, ''); body = body.replace(/<style[\\s\\S]*?<\\/style>/gi, ''); body = body.replace(/<noscript[\\s\\S]*?<\\/noscript>/gi, ''); body = body.replace(/<svg[\\s\\S]*?<\\/svg>/gi, ''); body = body.replace(/<iframe[\\s\\S]*?<\\/iframe>/gi, ''); body = body.replace(/<!--[\\s\\S]*?-->/g, ''); body = body.replace(/\\s+/g, ' ').trim(); const MAX_CHARS = 108000; if (body.length > MAX_CHARS) body = body.slice(0, MAX_CHARS); return body; } const html = $json.content; const bodyContent = extractCleanBody(html); return [{ json: { bodyContent } }];"
      },
