        "jsCode": "let queries = []; for (const item of $input.all()) { const user = item.json; const interests = user.interestedItems || []; const locations = user.interestedLocations || []; for (const product of interests) { for (const location of locations) { queries.push({ json: { query: `${product} for sale in ${location}`, product, location, user: { fullName: user.fullName, email: user.email, userType: user.userType, plan: user.plan } } }); } } } return queries;"
