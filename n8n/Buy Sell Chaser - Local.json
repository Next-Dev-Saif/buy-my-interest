    {
      "parameters": {
        "jsCode": "const userContext = $(\"Extract-Interested-Items\").first().json.user; const currentEmail = userContext.email; const groups = {}; const allQueries = $(\"Extract-Interested-Items\").all(); for (const item of $(\"Search-Google\").all()) { const inputIndex = item.pairedItem?.item; if (inputIndex !== undefined && allQueries[inputIndex]) { const inputData = allQueries[inputIndex].json; const itemUserEmail = inputData.user?.email; if (itemUserEmail === currentEmail) { if (!groups[currentEmail]) { groups[currentEmail] = { userEmail: currentEmail, results: [] }; } const organic = item.json.organic_results || []; groups[currentEmail].results.push(...organic.map(r => ({ ...r, category: inputData.product }))); } } } return Object.values(groups).map(g => ({ json: g }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2700,
        150
      ],
      "id": "8e8192f4-3741-4388-a921-37bedeae21a1",
      "name": "Aggregate-Search-Results"
